YOUTUBE_API_KEY=your_youtube_data_api_key_here
SPOTIFY_CLIENT_ID=your_spotify_client_id_here
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here
MUSICBOX_AUTH_USERNAME=your_private_username_here
MUSICBOX_AUTH_PASSWORD=your_private_password_here
FRONTEND_ORIGIN=http://localhost:5173
YOUTUBE_SEARCH_CACHE_TTL_SECONDS=300
DOWNLOADS_DIR=data/downloads
PLAYLISTS_DIR=data/playlists
EXPORTS_DIR=data/exports
MAX_CONCURRENT_DOWNLOADS=2
FFMPEG_BINARY=ffmpeg

# PO Token server URL (for YouTube bot detection bypass on cloud deployments)
# The bgutil HTTP server runs on this address to generate Proof-of-Origin tokens.
# Only needed when deploying to datacenter IPs (e.g. Render, AWS, etc.)
PO_TOKEN_SERVER_URL=http://127.0.0.1:4416
